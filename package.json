{
  "name": "automation-toolv2",
  "version": "1.2.9",
  "description": "Cognizance Health - Electron app to load studies and send DICOM images to PACS.",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electronmon .",
    "playwright-install": "playwright install chromium",
    "selenium-setup": "python -m pip install -r requirements-selenium.txt || py -3 -m pip install -r requirements-selenium.txt",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "dist": "npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "electronmon": {
    "patterns": [
      "!received-dicom/**",
      "!received-dicom/**/*"
    ]
  },
  "type": "module",
  "dependencies": {
    "adm-zip": "^0.5.17",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@electron/remote": "^2.1.3",
    "@types/node": "^24.3.1",
    "cross-env": "^10.0.0",
    "electron": "^38.1.0",
    "electron-builder": "^24.13.3",
    "electronmon": "^2.0.3",
    "playwright": "^1.55.0"
  },
  "build": {
    "appId": "com.web-previewer.app",
    "productName": "Cognizance Health",
    "directories": {
      "buildResources": "."
    },
    "files": [
      "**/*",
      "!node_modules/.cache/**",
      "!**/*.map"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "dcmtk",
        "to": "dcmtk",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "favicon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false
    }
  }
}
